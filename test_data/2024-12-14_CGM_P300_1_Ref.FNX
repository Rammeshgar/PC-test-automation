          <Tekst>
            <x:p>Navn :<x:br />CPR-nummer :<x:br />Vægt :<x:br />Højde :<x:br /><x:br /> &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;Nej &#160;&#160;&#160;Ja<x:br /><x:br />Er du gravid &#160;? &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;I hvilken uge<x:br />1. trimester er kontraindikation<x:br /><x:br />Ammer du ?<x:br /><x:br />Har du pacemaker &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;Kontraindikation<x:br /><x:br />Har du proteser i hjertet &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;Type, årgang ?<x:br /><x:br />Har du indsat rør i kranspulsåre<x:br />eller andre blodkar ? &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;Type, årgang ?<x:br /><x:br />Er du opereret i hjernen ? &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;Type, årgang ?<x:br /><x:br />Har du kunstige dele i mellemøret ? &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;Type, årgang ?<x:br /><x:br />Har du indsat elektroder til nervestimulation?<x:br /><x:br />Har du indsat Insulinpumpe ? &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;Type, årgang ?<x:br /><x:br />Har du indsat metaldele i knogler ? &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;Type, årgang ?<x:br /><x:br />Har du andre former for metal i kroppen ? &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;Type, årgang ?<x:br /><x:br />Er du opereret inden for de sidste 3 måneder ? &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;Hvilken ?<x:br /><x:br />Er du nyresyg ?<x:br /><x:br />Har du klaustrofobi ?<x:br /><x:br />Har du problemer med at ligge stille ?<x:br /><x:br />Er du indforstået med at få en indsprøjtning af<x:br />kontrastvæske i forbindelse med undersøgel-<x:br />sen, hvis det skønnes nødvendigt ?<x:br /><x:br /><x:br />Hvis du er blevet opereret og har svaret ja til nogle af spørgsmålene<x:br />skal du også oplyse, hvilket sygehus og afdeling, du er blevet ope-<x:br />reret på, og hvornår det skete. Det kan i så fald være nødvendigt at fremskaffe en gammel journal, hvilket krævet din tilladelse. Med din underskrift nedenfor markerer du også, at du giver tilladelse hertil.<x:br /><x:br />Dato : &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;Navn : &#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;&#160;CPR-nummer<x:br /><x:br />Har du behov for smertestillende/beroligende medicin til scanningen, skal den ordineres af din egen læge eller henvisende læge. Medicinen kan efter aftale medbringes eller indtages før undersøgelsen. BILLEDDIAGNOSTISK AFD. HAR IKKE MEDICIN<x:br /><x:br /><x:br />&#160;</x:p>
          </Tekst>
          <BehandlerIdentifikator>M</BehandlerIdentifikator>
        </NoteStruktur>
